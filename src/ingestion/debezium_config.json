{
  "name": "shift-postgres-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",

    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "shift",
    "database.password": "shift_dev_password",
    "database.dbname": "shift",

    "topic.prefix": "shift",
    "schema.include.list": "public",
    "table.include.list": "public.customers,public.products,public.orders,public.inventory,public.shipments",

    "plugin.name": "pgoutput",
    "publication.name": "shift_pub",
    "slot.name": "shift_slot",
    "snapshot.mode": "initial",

    "decimal.handling.mode": "precise",
    "time.precision.mode": "connect",
    "tombstones.on.delete": "true",

    "max.batch.size": "2048",
    "max.queue.size": "8192",
    "poll.interval.ms": "500",

    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry:8081",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081"
  }
}
