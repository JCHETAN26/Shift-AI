# ─────────────────────────────────────────────────────────────
# Shift.ai environment — copy to .env and fill in real values.
# Zero hardcoded credentials anywhere else in the repo.
# ─────────────────────────────────────────────────────────────

# --- Source: PostgreSQL (WAL/logical replication enabled) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shift
POSTGRES_USER=shift
POSTGRES_PASSWORD=shift_dev_password
# Connection string used by Python tooling on the host (seed, reconcile)
# Host port is 5435 to avoid colliding with other local Postgres instances.
POSTGRES_DSN=postgresql://shift:shift_dev_password@localhost:5435/shift

# --- Kafka + Schema Registry ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BOOTSTRAP_SERVERS_HOST=localhost:29092
SCHEMA_REGISTRY_URL=http://schema-registry:8081
SCHEMA_REGISTRY_URL_HOST=http://localhost:8081

# --- Debezium Connect ---
CONNECT_URL=http://localhost:8083
DEBEZIUM_TOPIC_PREFIX=shift

# --- Qdrant (RAG catalog vector store) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=shift_catalog

# --- Delta Lake (local warehouse paths inside the spark container) ---
DELTA_BRONZE_PATH=/data/delta/bronze
DELTA_SILVER_PATH=/data/delta/silver

# --- Snowflake (Gold layer — free trial, external service) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=SHIFT_WH
SNOWFLAKE_DATABASE=SHIFT
SNOWFLAKE_SCHEMA=GOLD

# --- LLM provider (provider-agnostic client picks based on what's set) ---
# Supported: anthropic | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Embeddings for the RAG catalog
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Seed sizing (override for faster local runs) ---
SEED_CUSTOMERS=100000
SEED_ORDERS=500000
SEED_PRODUCTS=10000
SEED_INVENTORY=50000
SEED_SHIPMENTS=200000
